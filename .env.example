# PostgreSQL connection string (Prisma).
# On Vercel: Storage -> Create Database -> Neon (Postgres) -> Connect Project,
# then copy the DATABASE_URL it creates. Prefer the DIRECT (unpooled) string.
# Local dev can point at the same database.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign session tokens (JWT). Generate your own with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-me-with-a-long-random-string"

# Admin account created by `npm run db:seed`
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@snailcream.example"
ADMIN_PASSWORD="change-me-please"

# Set to "true" to also create a demo customer with sample invoices
SEED_DEMO_DATA="true"
