generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         String   @default("CUSTOMER") // CUSTOMER | ADMIN
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Order {
  id               String   @id @default(cuid())
  invoiceNumber    String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  productName      String   @default("Snail Cream Set — 5 x 10g")
  unitPriceCents   Int      @default(1500)
  quantity         Int      @default(1)
  amountCents      Int
  currency         String   @default("EUR")
  paymentMethod    String   @default("GIFT_CARD") // GIFT_CARD | BANK_TRANSFER | PAYPAL
  paymentReference String?
  status           String   @default("PENDING") // PENDING | PAID | SHIPPED | DELIVERED | CANCELLED
  trackingNumber   String?
  carrier          String?
  shippingName     String
  shippingAddress  String
  shippingCity     String
  shippingPostal   String
  shippingCountry  String   @default("Germany")
  notes            String?
  orderedAt        DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
